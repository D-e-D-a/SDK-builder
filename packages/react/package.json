  },
  "dependencies": {
    "@embed-sdk/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  }
}
