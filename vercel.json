{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @embed-sdk/widget build",
  "outputDirectory": "apps/widget/dist",
  "rewrites": [
    {
      "source": "/embed",
      "destination": "/embed.html"
    }
  ]
}
