# ── EmbedSDK Configuration ───────────────────────────────────────────────────
#
# Copy this file to .env.development and .env.production, then fill in your
# values. Run `pnpm build` (or `pnpm --filter @embed-sdk/loader build`) to
# bake these into the embed.js IIFE.
#
# You never need to touch data-* attributes or window.EmbedSDKConfig for normal
# deployments — everything comes from here.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the widget iframe page
VITE_WIDGET_URL=https://widget.example.com/embed

# Origin of the widget iframe (must match the iframe's actual origin exactly)
VITE_WIDGET_ORIGIN=https://widget.example.com

# URL to the pre-built core SDK IIFE bundle (served from your CDN or same origin)
VITE_SDK_URL=https://cdn.example.com/embed-sdk-core.iife.js

# Endpoint the loader will GET to fetch a short-lived auth token.
# Response must be JSON: { "token": "..." }
# Leave empty if you provide window.EmbedSDKConfig.getToken at runtime instead.
VITE_TOKEN_URL=/api/embed-token
